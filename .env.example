# Local Development Environment Variables
# Copy this to .env and update with your values

# Database (for local development, use docker-compose)
DATABASE_URL=postgresql://civica:civica123@localhost:5433/civica_dev

# Supabase (get these from your Supabase project)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Application
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:8080

# Claude AI (for text enhancement feature)
CLAUDE_API_KEY=your-api-key-here
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# OpenAI (for content moderation)
OPENAI_API_KEY=your-openai-api-key-here

# Resend (for email notifications)
RESEND_API_KEY=your-resend-api-key-here
# RESEND_FROM_EMAIL=Civiti <noreply@civiti.ro>
# RESEND_FRONTEND_BASE_URL=http://localhost:4200

# Expo Push Notifications (optional — works without access token for low volume)
# EXPO_PUSH_ACCESS_TOKEN=your-expo-access-token-here

# Optional: Override settings
# PORT=8080