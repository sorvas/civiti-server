{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Database=civica_dev;Username=postgres;Password=password"
  },
  "Supabase": {
    "Url": "",
    "AnonKey": "",
    "ServiceRoleKey": ""
  },
  "JwtSettings": {
    "ValidIssuer": "",
    "ValidAudience": "authenticated",
    "RequireHttpsMetadata": true,
    "ValidateIssuerSigningKey": true
  },
  "JwtValidation": {
    "JwksUrl": "",
    "ValidIssuer": "",
    "ValidAudience": "authenticated",
    "JwksCacheTtlMs": 3600000,
    "ClockSkew": "00:01:00",
    "RequireHttpsMetadata": true,
    "MaxRetries": 3,
    "RetryDelayMs": 1000,
    "HttpTimeoutSeconds": 30,
    "LegacyJwtSecret": "",
    "EnableLegacyFallback": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "Railway": {
    "DatabaseUrl": "$DATABASE_URL",
    "Port": "$PORT"
  }
